  m_Script: {fileID: 11500000, guid: 5b497bd0e8a40b447aea6dea17fd68fb, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::StorySceneManager
  dialogueText: {fileID: 1730493727}
  displayImage: {fileID: 1828432436}
  typingSpeed: 0.03
  storyFlow:
  - sentence: "\uC5B4\uB290 \uBA3C \uC61B\uB0A0 \uBA3C \uB098\uB77C\uC5D0 \uC5B4\uB5A0\uD55C
      \uC18C\uC6D0\uC774\uB77C\uB3C4 \uC774\uB8E8\uC5B4\uC900\uB2E4\uB294 \uC131\uBC30\uC5D0
      \uB300\uD55C \uC18C\uBB38\uC774 \uB4E4\uB824\uC654\uC2B5\uB2C8\uB2E4."
    illustration: {fileID: -2729553823220738376, guid: db5fd8cacf070504b9aea8c0b613282d, type: 3}
  - sentence: "\uADF8 \uC18C\uBB38\uC740 \uC74C\uC720\uC2DC\uC778\uB4E4\uC758 \uB9D0\uC744
      \uAC74\uB108 \uC77C\uBC18\uC801\uC778 \uBC31\uC131\uB4E4\uB9C8\uC800\uB3C4
      \uBAA8\uB450 \uC54C\uC815\uB3C4\uB85C \uC720\uBA85\uD574\uC84C\uC2B5\uB2C8\uB2E4."
    illustration: {fileID: 0}
  - sentence: "\uC655\uC740 \uC774\uC18C\uC2DD\uC744 \uB4E3\uACE0\uC11C \uC790\uC2E0\uC758
